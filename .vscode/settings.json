{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv-1/bin/python",
  "python.analysis.typeCheckingMode": "basic",
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["tests"],
  "editor.formatOnSave": true,
  "files.exclude": {
    "**/.venv": true,
    "**/.venv-1": true,
    "**/.git": true
  }
}
