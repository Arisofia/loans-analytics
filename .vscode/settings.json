{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.terminal.useEnvFile": true,
  "python.envFile": "${workspaceFolder}/.env",
  "python.analysis.typeCheckingMode": "basic",
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": [
    "tests"
  ],
  "editor.formatOnSave": true,
  "files.exclude": {
    "**/.venv": true,
    "**/.venv-1": true,
    "**/.git": true,
    "**/node_modules": true,
    "**/__pycache__": true,
    "**/.mypy_cache": true,
    "**/.pytest_cache": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.venv": true,
    "**/data/output": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.venv/**": true,
    "**/.venv-1/**": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/__pycache__/**": true,
    "**/.mypy_cache/**": true,
    "**/.pytest_cache/**": true,
    "**/data/output/**": true,
    "**/archives/**": true,
    "**/.ruff_cache/**": true
  },
  "files.associations": {
    ".coveragerc": "ini",
    "*.coveragerc": "ini"
  },
  "java.compile.nullAnalysis.mode": "automatic",
  "sonarlint.connectedMode.project": {
    "connectionId": "abaco-technol",
    "projectKey": "abaco-loans-analytics"
  },
  "sonarlint.disableTelemetry": true,
  "sonarlint.analysisExcludesStandalone": {
    "**/node_modules/**": true,
    "**/.venv/**": true,
    "**/data/**": true,
    "**/__pycache__/**": true,
    "**/archives/**": true
  },
  "sonarlint.output.showAnalyzerLogs": false,
  "sonarlint.output.showVerboseLogs": false,
  "java.configuration.updateBuildConfiguration": "automatic",
  "zencoder.mcpServers": {
    "github": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "<YOUR_TOKEN>"
      }
    },
    "memory": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "-v",
        "claude-memory:/app/dist",
        "--rm",
        "mcp/memory"
      ]
    }
  },
  "inlineChat.notebookAgent": true,
  "inlineChat.finishOnType": true,
  "inlineChat.enableV2": true,
  "chat.useNestedAgentsMdFiles": true,
  "chat.tools.terminal.ignoreDefaultAutoApproveRules": true,
  "chat.tools.terminal.autoReplyToPrompts": true,
  "chat.todoListTool.writeOnly": true,
  "chat.todoListTool.descriptionField": true,
  "chat.renderRelatedFiles": true,
  "chat.restoreLastPanelSession": true,
  "chat.mcp.gallery.enabled": true,
  "chat.mcp.discovery.enabled": {
    "claude-desktop": true,
    "windsurf": true,
    "cursor-global": true,
    "cursor-workspace": true
  },
  "chat.mcp.assisted.nuget.enabled": true,
  "chat.edits2.enabled": true,
  "chat.editor.wordWrap": "on",
  "chat.disableAIFeatures": false,
  "chat.checkpoints.showFileChanges": true,
  "chat.customAgentInSubagent.enabled": true,
  "chat.allowAnonymousAccess": true,
  "azureFunctions.deploySubpath": ".",
  "azureFunctions.projectLanguage": "PowerShell",
  "azureFunctions.projectRuntime": "~4",
  "debug.internalConsoleOptions": "neverOpen",
  "yaml.schemas": {
    "https://www.schemastore.org/sourcehut-build-0.65.0.json": "config/kpi_definitions.yaml",
    "https://json.schemastore.org/github-workflow.json": ".github/workflows/*.{yml,yaml}"
  },
  "github-actions.workflows.pinned.workflows": [
    "abaco-loans-analytics/.github/workflows/agent-orchestrator.yml"
  ],
  "chat.useAgentSkills": true,
  "mssql.enableSqlParser": false,
  "extensions.ignoreRecommendations": false,
  "extensions.autoCheckUpdates": true,
  "extensions.autoUpdate": false,
  // Disable problematic extensions for this workspace
  "google.geminicodeassist": {
    "enabled": false
  },
  "zencoderai.zencoder": {
    "enabled": false
  },
  "trunk.io": {
    "enabled": false
  }
}