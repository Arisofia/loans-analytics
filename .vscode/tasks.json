{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run tests (pytest)",
      "type": "shell",
      "command": "bash -c 'source \"${workspaceFolder}/.venv/bin/activate\" && exec pytest -q'",
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "Coverage",
      "type": "shell",
      "command": "bash -lc 'source ${workspaceFolder}/.venv/bin/activate && coverage run -m pytest && coverage report -m'"
    },
    {
      "type": "shell",
      "label": "func: host start",
      "command": "func host start",
      "problemMatcher": "$func-powershell-watch",
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ]
}