{
  "title": "Supabase PostgreSQL Monitoring",
  "tags": ["supabase", "postgresql", "production"],
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 1,
  "refresh": "30s",
  "uid": "supabase-postgresql",
  "panels": [
    {
      "id": 1,
      "title": "Database Connections",
      "type": "graph",
      "datasource": "Prometheus Local",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "pg_stat_database_num_backends{job=\"supabase-db\"}",
          "legendFormat": "{{server}}",
          "refId": "A"
        }
      ],
      "yaxes": [
        {
          "format": "short",
          "label": "Connections"
        },
        {
          "format": "short"
        }
      ]
    },
    {
      "id": 2,
      "title": "Transactions Per Second",
      "type": "graph",
      "datasource": "Prometheus Local",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit_total{job=\"supabase-db\"}[5m])",
          "legendFormat": "Commits",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback_total{job=\"supabase-db\"}[5m])",
          "legendFormat": "Rollbacks",
          "refId": "B"
        }
      ],
      "yaxes": [
        {
          "format": "ops",
          "label": "TPS"
        },
        {
          "format": "short"
        }
      ]
    },
    {
      "id": 3,
      "title": "Query Operations",
      "type": "graph",
      "datasource": "Prometheus Local",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_fetched_total{job=\"supabase-db\"}[5m])",
          "legendFormat": "Rows Fetched",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_tup_inserted_total{job=\"supabase-db\"}[5m])",
          "legendFormat": "Rows Inserted",
          "refId": "B"
        },
        {
          "expr": "rate(pg_stat_database_tup_updated_total{job=\"supabase-db\"}[5m])",
          "legendFormat": "Rows Updated",
          "refId": "C"
        },
        {
          "expr": "rate(pg_stat_database_tup_deleted_total{job=\"supabase-db\"}[5m])",
          "legendFormat": "Rows Deleted",
          "refId": "D"
        }
      ],
      "yaxes": [
        {
          "format": "ops",
          "label": "Rows/sec"
        },
        {
          "format": "short"
        }
      ]
    },
    {
      "id": 4,
      "title": "PgBouncer Connection Pool",
      "type": "graph",
      "datasource": "Prometheus Local",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "pgbouncer_pools_server_active_connections{job=\"supabase-db\"}",
          "legendFormat": "Active - {{exported_database}}",
          "refId": "A"
        },
        {
          "expr": "pgbouncer_pools_server_idle_connections{job=\"supabase-db\"}",
          "legendFormat": "Idle - {{exported_database}}",
          "refId": "B"
        }
      ],
      "yaxes": [
        {
          "format": "short",
          "label": "Connections"
        },
        {
          "format": "short"
        }
      ]
    },
    {
      "id": 5,
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "datasource": "Prometheus Local",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 6,
        "h": 6
      },
      "targets": [
        {
          "expr": "sum(pg_stat_database_blks_hit_total{job=\"supabase-db\"}) / (sum(pg_stat_database_blks_hit_total{job=\"supabase-db\"}) + sum(pg_stat_database_blks_read_total{job=\"supabase-db\"}))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 0.9,
                "color": "yellow"
              },
              {
                "value": 0.95,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Disk Usage",
      "type": "gauge",
      "datasource": "Prometheus Local",
      "gridPos": {
        "x": 6,
        "y": 16,
        "w": 6,
        "h": 6
      },
      "targets": [
        {
          "expr": "(node_filesystem_size_bytes{job=\"supabase-db\",mountpoint=\"/\"} - node_filesystem_avail_bytes{job=\"supabase-db\",mountpoint=\"/\"}) / node_filesystem_size_bytes{job=\"supabase-db\",mountpoint=\"/\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 0.7,
                "color": "yellow"
              },
              {
                "value": 0.9,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Memory Usage",
      "type": "graph",
      "datasource": "Prometheus Local",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "expr": "(node_memory_MemTotal_bytes{job=\"supabase-db\"} - node_memory_MemAvailable_bytes{job=\"supabase-db\"}) / node_memory_MemTotal_bytes{job=\"supabase-db\"} * 100",
          "legendFormat": "Memory Used %",
          "refId": "A"
        }
      ],
      "yaxes": [
        {
          "format": "percent",
          "label": "Usage %",
          "max": 100,
          "min": 0
        },
        {
          "format": "short"
        }
      ]
    },
    {
      "id": 8,
      "title": "CPU Usage",
      "type": "graph",
      "datasource": "Prometheus Local",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{job=\"supabase-db\",mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU Usage %",
          "refId": "A"
        }
      ],
      "yaxes": [
        {
          "format": "percent",
          "label": "Usage %",
          "max": 100,
          "min": 0
        },
        {
          "format": "short"
        }
      ]
    },
    {
      "id": 9,
      "title": "Disk I/O",
      "type": "graph",
      "datasource": "Prometheus Local",
      "gridPos": {
        "x": 12,
        "y": 22,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total{job=\"supabase-db\"}[5m])",
          "legendFormat": "Read - {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_written_bytes_total{job=\"supabase-db\"}[5m])",
          "legendFormat": "Write - {{device}}",
          "refId": "B"
        }
      ],
      "yaxes": [
        {
          "format": "Bps",
          "label": "Bytes/sec"
        },
        {
          "format": "short"
        }
      ]
    }
  ]
}
