                    "format": "table",
                    "group": [],
                    "metricColumn": "none",
                    "rawQuery": true,
                    "rawSql": "SELECT\n  kd.name as \"KPI Name\",\n  kd.category as \"Category\",\n  kv.value_num as \"Current Value\",\n  kd.unit as \"Unit\",\n  kv.status as \"Status\",\n  kv.as_of_date as \"Last Updated\"\nFROM monitoring.kpi_definitions kd\nLEFT JOIN LATERAL (\n  SELECT * FROM monitoring.kpi_values\n  WHERE kpi_key = kd.kpi_key\n  ORDER BY as_of_date DESC\n  LIMIT 1\n) kv ON true\nORDER BY kd.category, kd.name",
