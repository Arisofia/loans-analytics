* text=auto

# Keep source/config/docs normalized to LF across platforms
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.sh text eol=lf

# Keep Windows-native script endings
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
