{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location": {
            "value": "eastus"
        },
        "webAppName": {
            "value": "abaco-webapp"
        },
        "storageAccountName": {
            "value": "abacostorage"
        },
        "sqlServerName": {
            "value": "abacosqlserver"
        },
        "sqlDbName": {
            "value": "abacodb"
        },
        "sqlAdminLogin": {
            "value": "sqladminuser"
        },
        "sqlAdminPassword": {
            "value": "${SQL_ADMIN_PASSWORD}"
        },
        "allowAzureServices": {
            "value": true
        },
        "sqlFirewallRules": {
            "value": []
        }
    }
}