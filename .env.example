# Azure Configuration
# Azure credentials should be provided via secured environment variables or secrets management.
# AZURE_SUBSCRIPTION_ID=your_subscription_id
# AZURE_TENANT_ID=your_tenant_id
# AZURE_CLIENT_ID=your_client_id
# AZURE_CLIENT_SECRET=your_client_secret (store in GitHub Secrets)

# Azure Storage
AZURE_STORAGE_ACCOUNT_NAME=xxx
AZURE_STORAGE_CONNECTION_STRING=xxx
AZURE_STORAGE_CONTAINER_NAME=kpi-exports

# Azure Key Vault
AZURE_KEY_VAULT_URL=xxx

# Azure App Service
AZURE_WEBAPP_NAME=abaco-analytics-dashboard
AZURE_RESOURCE_GROUP=AI-MultiAgent-Ecosystem-RG

# Application Insights / Tracing
# APPLICATIONINSIGHTS_CONNECTION_STRING=your_instrumentation_connection_string (store securely)
AZURE_APPINSIGHTS_SERVICE_NAME=abaco-loans-analytics
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Supabase Configuration
# Supabase configuration (store secrets securely and set in environment)
# SUPABASE_URL=your_supabase_url
# SUPABASE_ANON_KEY=your_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# NEXT_PUBLIC_SUPABASE_URL=your_public_url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_public_anon_key


# API Keys
# The following keys are placeholders and **must** be set via environment variables or GitHub Secrets.
# Do NOT commit real credentials. Example:
# OPENAI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here
# GEMINI_API_KEY=your_key_here
# PERPLEXITY_API_KEY=your_key_here
# XAI_API_KEY=your_key_here

# Application Configuration
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# Observability
# OPIK_TOKEN=your_opik_token (store securely)
# PHOENIX_TOKEN=your_phoenix_token (store securely)

# Environment
NODE_ENV=development
PYTHON_ENV=development

# --- Docker Compose (local) ---
# Used by docker-compose.yml
# Frontend expects NEXT_PUBLIC_* (and may also use SUPABASE_URL/ANON_KEY in some scripts)
# Backend (dashboard) does not require Supabase by default, but OPENAI/HUBSPOT may be used by other modules.

