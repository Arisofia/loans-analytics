# Azure Configuration
# Set sensitive Azure credentials in your environment or GitHub Secrets. Do NOT commit real credentials.
# AZURE_SUBSCRIPTION_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# Azure Storage
AZURE_STORAGE_ACCOUNT_NAME=xxx
AZURE_STORAGE_CONNECTION_STRING=xxx
AZURE_STORAGE_CONTAINER_NAME=kpi-exports

# Azure Key Vault
AZURE_KEY_VAULT_URL=xxx

# Azure App Service
AZURE_WEBAPP_NAME=abaco-analytics-dashboard
AZURE_RESOURCE_GROUP=AI-MultiAgent-Ecosystem-RG

# Application Insights / Tracing
# APPLICATIONINSIGHTS_CONNECTION_STRING=
AZURE_APPINSIGHTS_SERVICE_NAME=abaco-loans-analytics
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Supabase Configuration
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=


# API Keys
# (Configure API keys in your environment or GitHub Actions Secrets; do NOT commit them to source control)
# e.g., set provider API keys (e.g., OpenAI or Anthropic) in your runtime environment or as Actions secrets (do not commit keys)

# Application Configuration
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# Observability
# OPIK_TOKEN=
# PHOENIX_TOKEN=

# Environment
NODE_ENV=development
PYTHON_ENV=development

# --- Docker Compose (local) ---
# Used by docker-compose.yml
# Frontend expects NEXT_PUBLIC_* (and may also use SUPABASE_URL/ANON_KEY in some scripts)
# Backend (dashboard) does not require Supabase by default, but OPENAI/HUBSPOT may be used by other modules.

