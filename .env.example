# Example .env file

# The provider for the agent
AGENT_PROVIDER=

# API keys for different providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# OpenTelemetry configuration
ENABLE_OTEL=
OTEL_ENDPOINT=

# Logging configuration
LOG_LEVEL=

# Database configuration
DATABASE_URL=postgresql://n8n:n8n@localhost:5432/n8n
SUPABASE_URL=
SUPABASE_KEY=

# n8n Workflow Orchestration (REQUIRED)
# SECURITY: Set a strong password - do not use default values
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=    # REQUIRED: Set a strong password here
N8N_HOST=localhost
N8N_WEBHOOK_URL=http://localhost:5678

# PostgreSQL Database
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n
