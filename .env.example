# Example Environment Configuration
# Copy this file to .env.local and fill in your actual values
# .env.local is gitignored and will not be committed

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from: Supabase Dashboard → Settings → API
# These NEXT_PUBLIC_* vars are safe for frontend exposure
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_your_key_here

# Server-side only (NEVER expose in frontend)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_SECRET_API_KEY=sb_secret_your_key_here

# Direct PostgreSQL connection
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
SUPABASE_DATABASE_URL=postgresql://postgres:your_password@db.your-project-ref.supabase.co:5432/postgres

# Optional: Connection Pooler (recommended for serverless/high concurrency)
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:your_password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Project reference (extracted from URL)
SUPABASE_PROJECT_REF=your-project-ref

# JWT Secret (for manual token verification)
SUPABASE_JWT_SECRET=your_jwt_secret_here

# ============================================
# MULTI-AGENT SYSTEM CONFIGURATION
# ============================================
# The provider for the agent (openai, anthropic, gemini)
AGENT_PROVIDER=openai

# API keys for different LLM providers
OPENAI_API_KEY=sk-your_openai_key_here
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
GEMINI_API_KEY=your_google_gemini_key_here

# LLM request timeout (seconds)
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3

# ============================================
# OBSERVABILITY & MONITORING
# ============================================
# OpenTelemetry configuration
ENABLE_OTEL=true
OTEL_ENDPOINT=http://localhost:4318

# Logging configuration (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Metrics exporter port (for Prometheus scraping)
METRICS_PORT=8000

# Azure Application Insights (optional)
APPLICATIONINSIGHTS_CONNECTION_STRING=your_connection_string_here

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Environment (development, staging, production)
NODE_ENV=development

# Next.js configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Pipeline configuration
PIPELINE_RUN_SCHEDULE=0 2 * * *  # Daily at 2 AM
