# Example Environment Configuration
# Copy this file to .env and fill in your actual values
# .env and .env.local are gitignored and will not be committed

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from: Supabase Dashboard → Settings → API
# These NEXT_PUBLIC_* vars are safe for frontend exposure
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=<your-supabase-publishable-key>

# ── Python backend uses these (REQUIRED for /analytics/full-analysis,
#    /monitoring/events, and integration tests) ──
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
# SUPABASE_HISTORICAL_KPI_TABLE=kpi_timeseries_daily

# Server-side only (NEVER expose in frontend)
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Direct PostgreSQL connection
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
SUPABASE_DATABASE_URL=postgresql://postgres:your_password@db.your-project-ref.supabase.co:5432/postgres

# Optional: Connection Pooler (required for monitoring API endpoints)
# Use session mode (port 5432) for asyncpg prepared statement support
# Find your region in Supabase Dashboard → Settings → Infrastructure
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:your_password@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Project reference (extracted from URL)
SUPABASE_PROJECT_REF=your-project-ref

# JWT Secret (for manual token verification)
SUPABASE_JWT_SECRET=your_jwt_secret_here

# ============================================
# MULTI-AGENT SYSTEM CONFIGURATION
# ============================================
# The provider for the agent (openai, anthropic, gemini)
AGENT_PROVIDER=openai

# Historical context mode for multi-agent system (MOCK for tests, REAL for production)
HISTORICAL_CONTEXT_MODE=REAL

# API keys for different LLM providers
OPENAI_API_KEY=sk-your_openai_key_here
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
GEMINI_API_KEY=your_google_gemini_key_here
XAI_API_KEY=xai-your_grok_key_here
XAI_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-2-latest
# NOTE: Grok integration in this repo uses API key auth only (no email/password variables).

# LLM request timeout (seconds)
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3

# ============================================
# OBSERVABILITY & MONITORING
# ============================================
# OpenTelemetry configuration
ENABLE_OTEL=true
OTEL_ENDPOINT=http://localhost:4318

# Logging configuration (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Metrics exporter port (for Prometheus scraping)
METRICS_PORT=8000

# Azure Application Insights (optional)
APPLICATIONINSIGHTS_CONNECTION_STRING=your_connection_string_here

# Sentry error tracking (get DSN from sentry.io → Project Settings → Client Keys)
SENTRY_DSN=https://your-sentry-dsn@o123456.ingest.us.sentry.io/123456

# ============================================
# GOOGLE SHEETS CONFIGURATION
# ============================================
# Enable Google Sheets as a data source for the pipeline
# Get credentials from: Google Cloud Console → IAM & Admin → Service Accounts
# Generate JSON key and save to credentials/google-service-account.json
GOOGLE_SHEETS_CREDENTIALS_PATH=credentials/google-service-account.json
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id-here
GOOGLE_SHEETS_WORKSHEET=DESEMBOLSOS

# ============================================
# MONITORING STACK (docker-compose.yml (monitoring profile))
# ============================================
# Grafana admin password (change for production)
GRAFANA_ADMIN_PASSWORD=<set-a-strong-password-min-16-chars>

# Supabase database password (NOT the service role JWT key)
# Find at: Supabase Dashboard → Settings → Database → Connection string
SUPABASE_DB_PASSWORD=your_database_password_here

# Supabase anonymous key (used by Grafana REST API datasource)
# SUPABASE_ANON_KEY is already defined above — do not redefine here.
# Grafana REST datasource: reference the value set in the SUPABASE CONFIGURATION section.

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Environment (development, staging, production)
NODE_ENV=development
ENVIRONMENT=development

# FastAPI server settings (used by uvicorn)
API_HOST=127.0.0.1
API_PORT=8000

# Risk model backend (xgb: canonical, torch: experimental)
DEFAULT_RISK_MODEL_BACKEND=xgb

# Next.js configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Pipeline configuration
PIPELINE_RUN_SCHEDULE=0 2 * * *
# Daily at 2 AM — do not add inline comments to env values; parsers include them verbatim

# Dashboard webhook URL - pipeline POSTs here on completion
# Points to n8n webhook which creates monitoring events
DASHBOARD_WEBHOOK_URL=http://localhost:5678/webhook/pipeline-complete

# ============================================
# TESTING
# ============================================
# RUN_REAL_SUPABASE_TESTS=false        # set true to run @pytest.mark.integration
# RUN_E2E=0                            # set 1 to run tests marked @pytest.mark.e2e
# BACKEND_BASE_URL=http://localhost:8000
# FRONTEND_BASE_URL=http://localhost:8501   # local Docker dashboard default
# FRONTEND_BASE_URL=http://localhost:8000   # Azure startup.sh default
# MOCK=false                           # set true to mock LLM calls in agents
# HISTORICAL_CONTEXT_MODE=supabase     # supabase | csv | mock
