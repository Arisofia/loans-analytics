{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next node_modules dist build .cache coverage .venv __pycache__ .turbo out .swc .parcel-cache .pytest_cache .playwright .playwright-cache .storybook .vite .svelte-kit .nx .eslintcache && rm -f *.log *.bak *.old package-lock.old.json pnpm-lock.old.yaml yarn.lock.old .DS_Store",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "check-all": "npm run type-check && npm run lint && npm run format:check",
    "test:unit": "jest --config jest.config.js --colors --runInBand",
    "test:e2e": "playwright test",
    "test:e2e:ci": "npx playwright install --with-deps && npx playwright test --reporter=github",
    "e2e:seed": "node scripts/e2e/seed_test_data.js",
    "e2e:teardown": "node scripts/e2e/teardown_test_data.js"
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.48.1",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "cookie": "^1.1.1",
    "next": "15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@azure/static-web-apps-cli": "2.0.7",
    "@next/eslint-plugin-next": "^15.1.6",
    "@playwright/test": "^1.41.0",
    "@sentry/cli": "^3.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "autoprefixer": "^10.4.22",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv": "^16.1.0",
    "eslint": "^9.19.0",
    "eslint-config-next": "^15.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "^29.7.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "lodash": "4.17.23",
    "tmp": "0.2.5",
    "undici": "7.19.1"
  },
  "type": "module"
}
