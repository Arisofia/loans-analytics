      "targets": [
        {
          "format": "table",
          "group": [],
          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "SELECT\n  created_at as \"Time\",\n  COALESCE(payload->>'agent_role', source) as \"Agent\",\n  severity as \"Severity\",\n  event_type as \"Event\",\n  COALESCE(payload->>'comment', payload->>'message', payload::text) as \"Comment\"\nFROM monitoring.operational_events\nWHERE source IN ('agent', 'multi_agent', 'orchestrator', 'dashboard')\n   OR event_type ILIKE 'agent%'\n   OR payload ? 'agent_role'\nORDER BY created_at DESC\nLIMIT 200",
          "refId": "A",
          "select": [
            [
              {
                "params": ["*"],
                "type": "column"
              }
            ]
          ],
          "timeColumn": "created_at",
          "where": []
        }
