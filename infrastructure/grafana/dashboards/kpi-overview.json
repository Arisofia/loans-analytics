        {
          "format": "time_series",
          "group": [],
          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "SELECT\n  COALESCE(kv.computed_at, kv.\"timestamp\", kv.as_of_date::timestamptz) as time,\n  COALESCE(kd.name, kd.display_name, kv.kpi_key) as metric,\n  COALESCE(kv.value_num, kv.value) as value\nFROM public.kpi_values kv\nLEFT JOIN public.kpi_definitions kd ON kd.kpi_key = kv.kpi_key\nWHERE kv.as_of_date >= CURRENT_DATE - INTERVAL '30 days'\n  AND COALESCE(kv.value_num, kv.value) IS NOT NULL\nORDER BY time",
          "refId": "A",
          "select": [
            [
              {
                "params": ["value_num"],
                "type": "column"
              }
            ]
          ],
          "timeColumn": "as_of_date",
          "where": [
            {
              "name": "$__timeFilter",
              "params": [],
              "type": "macro"
            }
          ]
        }
      ],
