      "pluginVersion": "9.0.0",
      "targets": [
        {
          "format": "table",
          "group": [],
          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "WITH latest AS (\n  SELECT DISTINCT ON (kpi_key)\n    kpi_key,\n    COALESCE(value_num, value) AS value_num,\n    status,\n    as_of_date,\n    COALESCE(computed_at, \"timestamp\") AS computed_at,\n    created_at\n  FROM public.kpi_values\n  ORDER BY kpi_key, as_of_date DESC, COALESCE(computed_at, \"timestamp\") DESC NULLS LAST, created_at DESC NULLS LAST\n)\nSELECT\n  COALESCE(kd.name, kd.display_name, kd.kpi_key) as \"KPI Name\",\n  COALESCE(kd.category, 'Uncategorized') as \"Category\",\n  l.value_num as \"Current Value\",\n  kd.unit as \"Unit\",\n  COALESCE(l.status, 'n/a') as \"Status\",\n  COALESCE(l.computed_at, l.as_of_date::timestamptz) as \"Last Updated\"\nFROM public.kpi_definitions kd\nLEFT JOIN latest l ON l.kpi_key = kd.kpi_key\nORDER BY 2, 1",
          "refId": "A",
          "select": [
            [
              {
                "params": ["*"],
                "type": "column"
              }
            ]
          ],
          "timeColumn": "as_of_date",
          "where": []
        }
      ],
      "title": "KPI Status Table",
      "type": "table"
