          "metricColumn": "kpi_key",
          "rawQuery": true,
          "rawSql": "SELECT\n  date::timestamptz as time,\n  kpi_id as metric,\n  COALESCE(value_numeric, value_int::numeric) as value\nFROM public.historical_kpis\nWHERE date >= CURRENT_DATE - INTERVAL '90 days'\n  AND is_final = true\n  AND COALESCE(value_numeric, value_int::numeric) IS NOT NULL\nORDER BY date",
